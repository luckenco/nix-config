#!/usr/bin/env bash
set -euo pipefail

# Support jj (jujutsu) repos (primary here) as well as plain git.
# Falls back gracefully if neither is present.
if command -v jj >/dev/null 2>&1 && jj root >/dev/null 2>&1; then
  repo_root="$(jj root)"
elif command -v git >/dev/null 2>&1; then
  repo_root="$(git rev-parse --show-toplevel)"
else
  repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi
cd "$repo_root"

package_file="pkgs/grok-cli-latest.nix"
version="$(curl -fsSL https://x.ai/cli/stable | tr -d '[:space:]')"

if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[^[:space:]]+)?$ ]]; then
  echo "Invalid Grok version from stable channel: $version" >&2
  exit 1
fi

current_version="$(sed -n 's/^[[:space:]]*version = "\([^"]*\)";$/\1/p' "$package_file" | head -n 1)"
if [[ "$current_version" == "$version" ]]; then
  echo "Grok CLI already pinned at $version"
  exit 0
fi

prefetch_hash() {
  local platform="$1"
  nix store prefetch-file --json "https://x.ai/cli/grok-${version}-${platform}" \
    | sed -n 's/.*"hash":"\([^"]*\)".*/\1/p'
}

export GROK_VERSION="$version"
export GROK_HASH_MACOS_AARCH64="$(prefetch_hash macos-aarch64)"
export GROK_HASH_LINUX_AARCH64="$(prefetch_hash linux-aarch64)"
export GROK_HASH_LINUX_X86_64="$(prefetch_hash linux-x86_64)"

perl -0pi -e '
  s/version = "[^"]+";/version = "$ENV{GROK_VERSION}";/;
  s/(aarch64-darwin = \{\n\s+platform = "macos-aarch64";\n\s+hash = ")[^"]+(";)/$1$ENV{GROK_HASH_MACOS_AARCH64}$2/s;
  s/(aarch64-linux = \{\n\s+platform = "linux-aarch64";\n\s+hash = ")[^"]+(";)/$1$ENV{GROK_HASH_LINUX_AARCH64}$2/s;
  s/(x86_64-linux = \{\n\s+platform = "linux-x86_64";\n\s+hash = ")[^"]+(";)/$1$ENV{GROK_HASH_LINUX_X86_64}$2/s;
' "$package_file"

echo "Pinned Grok CLI $version in $package_file"
