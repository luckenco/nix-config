# direnv + nix-direnv is already configured globally for your shell.
#
# We currently have no devShell defined in this flake (review item #1 was
# explicitly skipped). Therefore we do NOT use `use flake` here — it would
# fail looking for devShells.<system>.default or packages.<system>.default.
#
# Instead we:
# - export FLAKE so scripts / tools that expect it can find the repo root
# - tell direnv to watch the key files so that changes to the flake trigger
#   a reload prompt (you can then run `direnv reload`)
export FLAKE="$(pwd)"
watch_file flake.nix
watch_file flake.lock

# If you ever want the full `use flake` experience (automatic dev shell on cd),
# we can add a small devShells.default later. Just say the word.
